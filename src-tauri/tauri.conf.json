{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Code Monitor",
  "version": "0.1.0",
  "identifier": "com.caiyiwen.claude-code-monitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Claude Code Monitor",
        "width": 360,
        "height": 480,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
